# Vertex AI (typical on Cloud Run)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=europe-west1
GOOGLE_GENAI_USE_VERTEXAI=True

# Or API key mode:
# GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=False

ADK_MODEL=gemini-3.1-pro-preview

# SQLite: local ./data/chief_of_staff.db; on Cloud Run defaults to /tmp/chief_of_staff.db when K_SERVICE is set
# CHIEF_OF_STAFF_DB_PATH=/tmp/chief_of_staff.db

# Optional Streamable HTTP MCP (Calendar/Gmail/Slack/Jira gateway)
# CHIEF_OF_STAFF_MCP_URL=https://your-mcp-host/mcp
# CHIEF_OF_STAFF_MCP_HEADERS={"Authorization":"Bearer ..."}

# ADK session persistence (optional)
# SESSION_SERVICE_URI=sqlite+aiosqlite:////tmp/adk_sessions.db

# CORS for main.py
# ALLOWED_ORIGINS=http://localhost:8080,*
